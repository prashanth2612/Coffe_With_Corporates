{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/api/index.js", "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"] },
    { "src": "/download/(.*)", "dest": "backend/api/index.js", "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"] },
    { "src": "/public/(.*)", "dest": "backend/api/index.js", "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"] },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}